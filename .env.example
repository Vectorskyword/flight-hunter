# ==============================================
# Clés API Amadeus (https://developers.amadeus.com)
# ==============================================
# Crée un compte gratuit, puis dans "My Self-Service Workspace",
# crée une nouvelle App pour obtenir ces deux clés.
AMADEUS_CLIENT_ID=ta_cle_publique_ici
AMADEUS_CLIENT_SECRET=ta_cle_secrete_ici

# Environnement Amadeus : "test" (gratuit, données limitées) ou "production"
AMADEUS_HOSTNAME=test

# Devise par défaut affichée dans les résultats
DEFAULT_CURRENCY=EUR
