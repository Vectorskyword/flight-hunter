# ==============================================
# Clé API SerpApi (https://serpapi.com)
# ==============================================
# Crée un compte gratuit (250 requêtes/mois), puis récupère ta clé sur :
# https://serpapi.com/manage-api-key
SERPAPI_KEY=ta_cle_serpapi_ici

# Devise par défaut affichée dans les résultats
DEFAULT_CURRENCY=EUR

# Pays utilisé pour les résultats Google Flights (code pays à 2 lettres)
DEFAULT_COUNTRY=fr

# Langue d'affichage des résultats
DEFAULT_LANGUAGE=fr
